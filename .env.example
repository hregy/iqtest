# Copy to .env for local dev, or set these as Render environment variables.

# Postgres connection string.
# Local dev:
DATABASE_URL=postgresql://iquser:iqpass@localhost:5432/iqtest
# Supabase (Project Settings > Database > Connection string > URI):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# Set PGSSL=true for Supabase / managed Postgres.
PGSSL=false

# Admin panel password (plaintext fallback).
ADMIN_PASSWORD=admin123
# Preferred: a bcrypt hash (overrides ADMIN_PASSWORD). Generate with:
#   npm run hash-admin -- 'your-strong-password'
ADMIN_PASSWORD_HASH=

# Secret used to sign admin + test-session tokens (use a long random string).
JWT_SECRET=dev-insecure-secret-change-me

# The non-expiring master voucher (admin/practice runs; never recorded).
ADMIN_VOUCHER=ADMIN-ALL-ACCESS

# Cloudflare Turnstile (bot challenge). Create a free widget at
# https://dash.cloudflare.com/?to=/:account/turnstile and paste both keys.
# Leave blank to disable the challenge (collection/detection still works).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# Port (Render sets this automatically in production).
PORT=3001
